      df_rslt['PCT'] = df_rslt[col]/len(df)*100\n","        df_rslt['TR'] = df_rslt[tgt]/df_rslt[col]*100\n","\n","    else:\n","        # create cuts\n","        p_list = [round(x/nbins, 2) for x in range(nbins)] + [1]\n","        fc_num = s.quantile(q=p_list, interpolation='lower').drop_duplicates()\n","        sorted_values = np.unique(fc_num.values.astype(np.float64))\n","        bins = np.r_[-np.inf, sorted_values, np.inf]\n","        labels =  fc_num.values\n","        cuts = pd.cut(df[col].astype(float), bins=bins, include_lowest=True)\n","\n","        # Left side\n","        df_left = cuts.value_counts(dropna=False).rename(col).to_frame()\n","        df_left_N = pd.Series({np.nan: s.isnull().sum()}, name=col).to_frame()\n","        df_left_F = pd.concat([df_left_N, df_left], axis=0).sort_index()\n","\n","        # Right side\n","        df_right = df.groupby(cuts)[tgt].sum().rename(tgt).to_frame()\n","        df_right_N = pd.Series({np.nan: df.loc[df[col].isnull(), tgt].sum()}, name=tgt).to_frame()\n","        df_right_F = pd.concat([df_right_N, df_right], axis=0).sort_index()\n","\n","        df_rslt = pd.concat([df_left_F, df_right_F], axis=1, sort=False)\n","        df_rslt['PCT'] = df_rslt[col] / len(df) * 100\n","        df_rslt['TR']  = df_rslt[tgt] / df_rslt[col] * 100\n","\n","        df_rslt.index = df_rslt.index.astype(str)\n","\n","    # graph\n","    fig, ax1 = plt.subplots()\n","    ax1.bar(df_rslt.index, df_rslt['PCT'])\n","    ax2 = ax1.twinx()\n","    ax2.plot(df_rslt.index, df_rslt['TR'], 'ro-')\n","    ax2.set_ylim([0, 100])\n","    fig.tight_layout()\n","    plt.show()\n","\n","    # IV\n","    df_rslt['Non_TARGET'] = df_rslt[col] - df_rslt[tgt]\n","    df_rslt['TP'] = df_rslt[tgt]/df_rslt[tgt].sum()\n","    df_rslt['NTP'] = df_rslt['Non_TARGET']/df_rslt['Non_TARGET'].sum()\n","    df_rslt['IV_c1'] = (df_rslt['TP']-df_rslt['NTP'])\n","    df_rslt['IV_c2'] = df_rslt['TP']/df_rslt['NTP']\n","    df_rslt['IV_c3'] = df_rslt['IV_c2'].apply(math.log)\n","    df_rslt['IV_c4'] = df_rslt['IV_c1'] * df_rslt['IV_c3']\n","    print(\"IV:\", int(df_rslt['IV_c4'].sum()*10000)/100,\"%\")\n","\n","    return df_rslt.drop(['IV_c1','IV_c2','IV_c3','IV_c4'], axis=1)"],"execution_count":188,"outputs":[]},{"cell_type":"code","metadata":{"id":"wDPZWOK1xB8f","colab":{"base_uri":"https://localhost:8080/","height":632},"executionInfo":{"status":"ok","timestamp":1766840146952,"user_tz":-540,"elapsed":720,"user":{"displayName":"원정인","userId":"06589647251186669025"}},"outputId":"dce335ac-2eb2-40e6-f727-651b09bafb91"},"source":["# 4.2.5 Coarseclassing 확인\n","tmp = raw[raw['DEV_VAL'] == 0].copy()\n","\n","tmp['LE0000001c'] = tmp['LE0000001c'].astype(str) # Coarse class 변수는 범주형으로 처리\n","\n","res = FC(tmp, 'LE0000001c', 'TARGET1', 20)\n","display(res)\n"],"execution_count":189,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["IV: 10.76 %\n"]},{"output_type":"display_data","data":{"text/plain":["            LE0000001c  TARGET1   PCT    TR  Non_TARGET   TP  NTP\n","LE0000001c                                                       \n","0                 5573     2202 64.47 39.51        3371 0.75 0.59\n","1                 3071      751 35.53 24.45        2320 0.25 0.41"],"text/html":["\n","  <div id=\"df-943d6452-d683-48da-a563-d4c8de2e7f1e\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>LE0000001c</th>\n","      <th>TARGET1</th>\n","      <th>PCT</th>\n","      <th>TR</th>\n","      <th>Non_TARGET</